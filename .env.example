# The Shelf - Environment Configuration
# Copy this file to .env and adjust values as needed

# PostgreSQL
POSTGRES_USER=shelf
POSTGRES_PASSWORD=shelf_secret
POSTGRES_DB=the_shelf

# Backend
SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=http://localhost:3000

# Optional: Google Books API key (raises the free quota above the
# unauthenticated per-day limit). Lookups work without it.
# GOOGLE_BOOKS_API_KEY=

# Frontend (port exposed to host)
PORT=3000

# Optional: Override backend URL for frontend (defaults to http://backend:8000 in Docker)
# BACKEND_URL=http://backend:8000

# Optional: Direct API URL for development (bypasses Next.js proxy)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Deploying with pre-built images from GHCR (docker compose pull && docker compose up -d)
# GHCR_OWNER=theshield2594
# TAG=latest
